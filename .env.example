# ─────────────────────────────────────────────────────────────
# cliniqboost AI — environment variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# ── Twilio ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE_WITH_YOUR_SID        # must start with AC
TWILIO_AUTH_TOKEN=REPLACE_WITH_YOUR_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_YOUR_NUMBER    # E.164, e.g. +12494212535

# When "false", ALL outbound SMS are mocked (logged, not sent) and messages are
# stored with twilio_sid 'MOCK'. Any other value (or unset) = real sends.
# Set to false while the Twilio account is payment-blocked / in testing.
TWILIO_SEND_ENABLED=true

# ── Anthropic (Claude) ────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_KEY

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=REPLACE_WITH_YOUR_URL
SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY    # used by the dashboard only
SUPABASE_SERVICE_KEY=REPLACE_WITH_YOUR_SERVICE_KEY

# ── n8n ───────────────────────────────────────────────────────
N8N_URL=REPLACE_WITH_YOUR_N8N_URL

# ── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
SERVER_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Pillar 2 — Lead Engine
# ─────────────────────────────────────────────────────────────

# Shared secret required on POST /webhooks/new-lead via the
# x-cliniqboost-secret header. Requests without a match get 401.
NEW_LEAD_WEBHOOK_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING

# Background schedulers (sequence sender + VIP sweep). "false" disables cron
# registration without a redeploy. Any other value (or unset) = enabled.
SCHEDULER_ENABLED=true

# Max touch_schedule rows processed per sequence-scheduler run (safety cap).
SCHEDULER_BATCH_SIZE=25

# Delay before the first new-lead nurture touch, in hours (default 22 — lands
# ~a day later but at a slightly different time of day).
NURTURE_TOUCH1_DELAY_HOURS=22

# VIP rebooking trigger: a VIP whose last_visit_date is older than this many
# days gets a 'rebooking' reminder (default 45).
VIP_REBOOK_THRESHOLD_DAYS=45

# Sub-system 5 — how long a waitlist slot offer stays open before it expires and
# cascades to the next person on the list (minutes, default 60).
WAITLIST_OFFER_WINDOW_MINUTES=60

# Dashboard login password. The dashboard reads patient data through a
# login-gated backend endpoint (service key, server-side) — the browser never
# gets the Supabase key. Set a strong value; required for the dashboard to work.
DASHBOARD_PASSWORD=REPLACE_WITH_A_STRONG_DASHBOARD_PASSWORD

# ─────────────────────────────────────────────────────────────
# Automatic Clinic Onboarding
# ─────────────────────────────────────────────────────────────

# Browser origins allowed to POST /onboarding/submit (comma-separated).
# Non-browser callers (no Origin header) are always allowed.
ONBOARDING_CORS_ORIGINS=https://cliniqboost.com,https://www.cliniqboost.com

# Max /onboarding/submit requests per IP per 15 minutes (default 10).
ONBOARDING_RATE_LIMIT_MAX=10

# Cloudflare Turnstile secret. Unset = Turnstile check is SKIPPED (logged),
# so the endpoint works before the frontend ships the widget.
# TURNSTILE_SECRET_KEY=REPLACE_WITH_YOUR_TURNSTILE_SECRET

# Formspree mirror of every new submission (email copy). "false" disables.
FORMSPREE_MIRROR_ENABLED=true
# FORMSPREE_URL=https://formspree.io/f/mojgalqa

# ── Onboarding — provisioning (Phase 2/3) ─────────────────────
# "true" enables automatic Twilio number purchase during provisioning
# (Phase 3). Keep false while the Twilio account is payment-blocked; the
# twilio_number integration_task stays pending and the number is attached
# manually.
TWILIO_PROVISION_ENABLED=false

# Provisioning retry cap: after this many failed attempts the job is marked
# 'failed' and the clinic 'provisioning_failed' (default 8; backoff 10m→12h).
PROVISIONING_MAX_ATTEMPTS=8

# "true" = internal endpoints (/internal/*, go-live) REQUIRE the HMAC
# signature headers, not just the shared secret. Leave false until every
# n8n workflow sends x-cliniqboost-timestamp/-signature.
INTERNAL_HMAC_REQUIRED=false
