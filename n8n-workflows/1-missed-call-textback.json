{
  "name": "cliniqboost — Missed Call Text-Back",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "twilio-missed-call",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-node",
      "name": "Twilio Missed Call Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.SERVER_URL }}/webhook/twilio/missed-call",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "To", "value": "={{ $json.To }}" },
            { "name": "From", "value": "={{ $json.From }}" },
            { "name": "CallDuration", "value": "={{ $json.CallDuration }}" }
          ]
        }
      },
      "id": "http-node",
      "name": "Forward to cliniqboost Server",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    }
  ],
  "connections": {
    "Twilio Missed Call Webhook": {
      "main": [[{ "node": "Forward to cliniqboost Server", "type": "main", "index": 0 }]]
    }
  }
}
